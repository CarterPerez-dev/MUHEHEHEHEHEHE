# =============================================================================
# ©AngelaMos | 2026
# .env.development
# =============================================================================
# Used by `just dev-*` (dev.compose.yml). Dev ports differ from prod so both
# stacks can run at once.
# =============================================================================

# --- Host ports (edge is nginx) ---
NGINX_HOST_PORT=8440
API_HOST_PORT=5440
FRONTEND_HOST_PORT=9440
POSTGRES_HOST_PORT=4440
REDIS_HOST_PORT=6440
OLLAMA_HOST_PORT=11440

# --- App ---
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON_FORMAT=false

# --- PostgreSQL ---
POSTGRES_USER=merit
POSTGRES_PASSWORD=merit
POSTGRES_DB=merit_db
DATABASE_URL=postgresql+asyncpg://merit:merit@db:5432/merit_db

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Security / JWT (dev only - rotate for prod) ---
SECRET_KEY=dev_secret_change_me_0123456789abcdef0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (same-origin via nginx; listed for direct access too) ---
CORS_ORIGINS=["http://localhost:8440","http://localhost:9440","http://localhost"]

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_EVALUATE=5/minute

# --- LLM: Gemini primary, local Ollama (qwen2.5:3b) fallback ---
GEMINI_API_KEY=AIzaSyBRzpPFnYR-K0jxMpVK_Hrfx7cD3oJb7Uc
LLM_PROVIDER=gemini
DEFAULT_MODEL=qwen2.5:3b
PRIMARY_MODEL=gemini-2.5-flash
FALLBACK_MODEL=qwen2.5:3b
OLLAMA_HOST=http://ollama:11434

# --- GitHub enrichment (best effort; needs a token to be useful) ---
GITHUB_ENRICHMENT=false
GITHUB_TOKEN=

# --- Uploads ---
MAX_UPLOAD_MB=10
