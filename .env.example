# =============================================================================
# ©AngelaMos | 2026
# .env.example
# =============================================================================
# Copy to `.env` for production (`just up`). Generate SECRET_KEY with:
#   openssl rand -base64 48
# =============================================================================

# --- Host ports ---
NGINX_HOST_PORT=8441

# --- App ---
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

# --- PostgreSQL ---
POSTGRES_USER=merit
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=merit_db
DATABASE_URL=postgresql+asyncpg://merit:CHANGE_ME_IN_PRODUCTION@db:5432/merit_db

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Security / JWT ---
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (same-origin via nginx) ---
CORS_ORIGINS=["https://your-domain.com"]

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_EVALUATE=5/minute

# --- LLM: Gemini primary, local Ollama (qwen2.5:3b) fallback ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
LLM_PROVIDER=gemini
DEFAULT_MODEL=qwen2.5:3b
PRIMARY_MODEL=gemini-2.5-flash
FALLBACK_MODEL=qwen2.5:3b
OLLAMA_HOST=http://ollama:11434

# --- GitHub enrichment (best effort; needs a token to be useful) ---
GITHUB_ENRICHMENT=false
GITHUB_TOKEN=

# --- Uploads ---
MAX_UPLOAD_MB=10

# --- Cloudflare Tunnel (for cloudflared.compose.yml) ---
CLOUDFLARE_TUNNEL_TOKEN=YOUR_TUNNEL_TOKEN_HERE
